{
  "title": "Resonate — Server Health",
  "uid": "resonate-server",
  "description": "Internal Resonate server metrics: HTTP API, AIO store, coroutines, promises, tasks",
  "tags": ["resonate", "server", "yugabyte"],
  "schemaVersion": 37,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "editable": true,
  "style": "dark",
  "annotations": { "list": [] },
  "links": [],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps",
          "thresholds": { "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }] } }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(http_requests_total[1m]))",
        "legendFormat": "req/s",
        "refId": "A"
      }]
    },

    {
      "id": 2,
      "title": "HTTP 5xx Error Rate",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": { "unit": "percentunit",
          "thresholds": { "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ] } }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m]))",
        "legendFormat": "5xx rate",
        "refId": "A"
      }]
    },

    {
      "id": 3,
      "title": "HTTP p99 Latency",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": { "unit": "s",
          "thresholds": { "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red",    "value": 0.5 }
            ] } }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "histogram_quantile(0.99, sum(rate(http_requests_duration_seconds_bucket[2m])) by (le))",
        "legendFormat": "p99",
        "refId": "A"
      }]
    },

    {
      "id": 4,
      "title": "Resonate Server Up",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN",  "color": "red"   } } },
            { "type": "value", "options": { "1": { "text": "UP",    "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ] }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "up{job=\"resonate\"}",
        "legendFormat": "resonate",
        "refId": "A"
      }]
    },

    {
      "id": 10,
      "title": "HTTP Request Rate by Path",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8,
            "showPoints": "never", "lineInterpolation": "smooth" },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_requests_total[$__rate_interval])) by (method, path, status)",
          "legendFormat": "{{method}} {{path}} {{status}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 11,
      "title": "HTTP Latency Percentiles by Path",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5,
            "showPoints": "never", "lineInterpolation": "smooth" },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_requests_duration_seconds_bucket[$__rate_interval])) by (le, path))",
          "legendFormat": "p99 {{path}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(http_requests_duration_seconds_bucket[$__rate_interval])) by (le, path))",
          "legendFormat": "p50 {{path}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 20,
      "title": "AIO Store Submission Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10,
            "showPoints": "never", "stacking": { "mode": "none" } },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(aio_submissions_total[$__rate_interval])) by (type, status)",
          "legendFormat": "{{type}} / {{status}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 21,
      "title": "AIO In-Flight Submissions",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max","last"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15,
            "showPoints": "never", "lineInterpolation": "smooth" },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "aio_submissions_in_flight",
          "legendFormat": "{{type}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "aio_worker_submissions_in_flight",
          "legendFormat": "worker {{worker}} / {{type}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 30,
      "title": "AIO Store Duration",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5,
            "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(aio_duration_seconds_bucket[$__rate_interval])) by (le, type))",
          "legendFormat": "p99 {{type}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(aio_duration_seconds_bucket[$__rate_interval])) by (le, type))",
          "legendFormat": "p50 {{type}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 31,
      "title": "Coroutines In-Flight",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","max","last"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10,
            "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "coroutines_in_flight",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 40,
      "title": "Promise State Transitions",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "barAlignment": 0, "lineWidth": 1,
            "fillOpacity": 70, "stacking": { "mode": "normal", "group": "A" } },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(promises_total[$__rate_interval])) by (state)",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 41,
      "title": "Task State Transitions",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean","sum"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "barAlignment": 0, "lineWidth": 1,
            "fillOpacity": 70, "stacking": { "mode": "normal", "group": "A" } },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(tasks_total[$__rate_interval])) by (state)",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    }

  ]
}