{
  "title": "Resonate — YugaByte Store",
  "uid": "resonate-yugabyte-store",
  "description": "Internal YugaByte store metrics: transaction health, error breakdown, connection pool state",
  "tags": ["resonate", "yugabyte", "store"],
  "schemaVersion": 37,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "editable": true,
  "style": "dark",
  "links": [],
  "templating": { "list": [] },
  "panels": [

    {
      "id": 1,
      "title": "Transactions — Total (range)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(increase(yugabyte_tx_total[$__range]))",
        "legendFormat": "total",
        "refId": "A"
      }]
    },

    {
      "id": 2,
      "title": "Transactions — OK (range)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute",
            "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(increase(yugabyte_tx_total{status=\"ok\"}[$__range]))",
        "legendFormat": "ok",
        "refId": "A"
      }]
    },

    {
      "id": 3,
      "title": "Transactions — Failed (range)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ] }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(increase(yugabyte_tx_total{status=\"failed\"}[$__range]))",
        "legendFormat": "failed",
        "refId": "A"
      }]
    },

    {
      "id": 4,
      "title": "Retry Attempts (range)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 50 }
            ] }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(increase(yugabyte_tx_retries_total[$__range]))",
        "legendFormat": "retries",
        "refId": "A"
      }]
    },

    {
      "id": 5,
      "title": "Active DB Connections",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "yugabyte_pool_connections{state=\"total\"}",
        "legendFormat": "total connections",
        "refId": "A"
      }]
    },

    {
      "id": 6,
      "title": "Total Errors (range)",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ] }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(increase(yugabyte_errors_total[$__range]))",
        "legendFormat": "total errors",
        "refId": "A"
      }]
    },

    {
      "id": 10,
      "title": "Transaction Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "ok" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(yugabyte_tx_total{status=\"ok\"}[$__rate_interval]))",
          "legendFormat": "ok",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(yugabyte_tx_total{status=\"failed\"}[$__rate_interval]))",
          "legendFormat": "failed",
          "refId": "B"
        }
      ]
    },

    {
      "id": 11,
      "title": "Transaction Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(yugabyte_tx_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(yugabyte_tx_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(yugabyte_tx_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 20,
      "title": "Errors by Type — Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 14, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "connection_failure" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "admin_shutdown" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "serialization_failure" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "raft_leader_election" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "deadlock_detected" },
            "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "context_deadline_exceeded" },
            "properties": [{ "id": "color", "value": { "fixedColor": "semi-dark-orange", "mode": "fixed" } }] }
        ]
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (error_type) (rate(yugabyte_errors_total[$__rate_interval]))",
        "legendFormat": "{{error_type}}",
        "refId": "A"
      }]
    },

    {
      "id": 21,
      "title": "Errors by Type — Share (range)",
      "type": "piechart",
      "gridPos": { "x": 14, "y": 13, "w": 10, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "pieType": "donut",
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }
      },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (error_type) (increase(yugabyte_errors_total[$__range]))",
        "legendFormat": "{{error_type}}",
        "refId": "A"
      }]
    },

    {
      "id": 30,
      "title": "Retry Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "fixedColor": "yellow", "mode": "fixed" }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(yugabyte_tx_retries_total[$__rate_interval]))",
        "legendFormat": "retries/s",
        "refId": "A"
      }]
    },

    {
      "id": 31,
      "title": "Connection Pool State",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "min": 0 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "total" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "acquired" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "idle" },
            "properties": [{ "id": "color", "value": { "fixedColor": "semi-dark-green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "constructing" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "yugabyte_pool_connections{state=\"total\"}",
          "legendFormat": "total",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "yugabyte_pool_connections{state=\"acquired\"}",
          "legendFormat": "acquired",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "yugabyte_pool_connections{state=\"idle\"}",
          "legendFormat": "idle",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "yugabyte_pool_connections{state=\"constructing\"}",
          "legendFormat": "constructing",
          "refId": "D"
        }
      ]
    },

    {
      "id": 50,
      "title": "DB Command Rate by Type",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 37, "w": 14, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 6 } }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (command) (rate(yugabyte_command_total[$__rate_interval]))",
        "legendFormat": "{{command}}",
        "refId": "A"
      }]
    },

    {
      "id": 51,
      "title": "Top Slow Commands — p99 Latency",
      "description": "p99 batch latency grouped by the dominant command in each batch. Commands at the top are the slowest. Labeled 'mixed' when a batch contains multiple equal command types.",
      "type": "table",
      "gridPos": { "x": 14, "y": 37, "w": 10, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "sortBy": [{ "displayName": "p99 latency", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "command" },
            "properties": [{ "id": "custom.width", "value": 220 }] },
          { "matcher": { "id": "byName", "options": "p99 latency" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": { "mode": "absolute",
                "steps": [
                  { "color": "green",  "value": null },
                  { "color": "yellow", "value": 0.05 },
                  { "color": "orange", "value": 0.1 },
                  { "color": "red",    "value": 0.25 }
                ] } }
            ] }
        ]
      },
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        { "id": "organize", "options": {
          "renameByName": { "Value": "p99 latency", "command": "command" },
          "excludeByName": { "Time": true }
        } }
      ],
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "topk(10, histogram_quantile(0.99, sum by (command, le) (rate(yugabyte_batch_duration_seconds_bucket[$__rate_interval]))))",
        "legendFormat": "{{command}}",
        "instant": true,
        "refId": "A"
      }]
    },

    {
      "id": 52,
      "title": "Batch Latency by Command (p95 timeseries)",
      "description": "p95 batch duration split by dominant command type. Shows which operations drive latency over time.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 46, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 6 },
          "thresholds": { "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red",    "value": 0.25 }
            ] }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.95, sum by (command, le) (rate(yugabyte_batch_duration_seconds_bucket[$__rate_interval])))",
        "legendFormat": "{{command}}",
        "refId": "A"
      }]
    },

    {
      "id": 40,
      "title": "Active Store Workers",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 30, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "min": 0 }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "aio_worker_count{type=\"store:yugabyte\"}",
        "legendFormat": "workers",
        "refId": "A"
      }]
    },

    {
      "id": 41,
      "title": "Worker In-Flight Submissions",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 30, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 8 }, "min": 0 }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "aio_worker_submissions_in_flight{type=\"store:yugabyte\"}",
        "legendFormat": "worker {{worker}}",
        "refId": "A"
      }]
    },

    {
      "id": 42,
      "title": "AIO Submission Duration (store)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 30, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(aio_duration_seconds_bucket{type=\"store:yugabyte\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95 aio",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(aio_duration_seconds_bucket{type=\"store:yugabyte\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50 aio",
          "refId": "B"
        }
      ]
    }

  ]
}